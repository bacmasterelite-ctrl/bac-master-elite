{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "BASE_PATH=/ PORT=3000 pnpm --filter @workspace/bac-master-elite run build",
  "outputDirectory": "artifacts/bac-master-elite/dist/public",
  "installCommand": "pnpm install --frozen-lockfile",
  "framework": null, 
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
