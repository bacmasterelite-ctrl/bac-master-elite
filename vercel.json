{
  "buildCommand": "cd artifacts/bac-master-elite && pnpm run build",
  "outputDirectory": "artifacts/bac-master-elite/dist/public",
  "installCommand": "cd artifacts/bac-master-elite && pnpm install",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
