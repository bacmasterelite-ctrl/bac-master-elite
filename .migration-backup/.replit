modules = ["nodejs-20", "web"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 8094
externalPort = 80

[[ports]]
localPort = 8095
externalPort = 3000

[[ports]]
localPort = 8096
externalPort = 3001

[[ports]]
localPort = 8097
externalPort = 3002

[[ports]]
localPort = 8098
externalPort = 3003

[[ports]]
localPort = 8099
externalPort = 8099

[[ports]]
localPort = 8100
externalPort = 4200

[nix]
channel = "stable-25_05"
